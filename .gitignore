# ---- data & big outputs (live on /tgen_labs, never in git) ----
runs/
run_12mer_scaffolding/
datasets/
logs/
err_out_files/
*.csv
*.parquet
*.cif
*.cif.gz
*.pdb
*.pdb.gz
*.npy
*.npz
*.h5

# ---- slurm ----
*.out
*.err
slurm-*

# ---- figures default-ignored; manuscript figures are re-included below ----
*.png
*.pdf

# ---- LaTeX build artifacts ----
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.toc
manuscript/*.log

# ---- python / cruft ----
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/
tmp/
*.point
*history.txt

# ============================================================
# Tracked exceptions (these ARE committed despite the rules above)
# ============================================================
# small derived results that figures/manuscript depend on
!results/
!results/README.md
!results/.gitkeep
!results/*.csv
!results/*.tsv
!results/*.json
# the living manuscript: its figures and the built PDF
!manuscript/figures/
!manuscript/figures/.gitkeep
!manuscript/figures/FIGURES.md
!manuscript/figures/*.png
!manuscript/figures/*.pdf
!manuscript/main.pdf
