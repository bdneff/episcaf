#!/usr/bin/env python3
from __future__ import annotations
import argparse
from pathlib import Path
import gzip
import numpy as np
import pandas as pd
import gemmi

AA3TO1 = {
 "ALA":"A","CYS":"C","ASP":"D","GLU":"E","PHE":"F","GLY":"G","HIS":"H","ILE":"I","LYS":"K","LEU":"L",
 "MET":"M","ASN":"N","PRO":"P","GLN":"Q","ARG":"R","SER":"S","THR":"T","VAL":"V","TRP":"W","TYR":"Y"
}

def read_structure(p: Path):
    s = str(p)
    if s.endswith(".gz"):
        with gzip.open(p, "rt") as f:
            doc = gemmi.cif.read_string(f.read())
        return gemmi.make_structure_from_block(doc.sole_block())
    if p.suffix.lower() == ".cif":
        doc = gemmi.cif.read(str(p))
        return gemmi.make_structure_from_block(doc.sole_block())
    return gemmi.read_structure(str(p))

def get_chainA(st):
    m = st[0]
    for ch in m:
        if ch.name == "A":
            return ch
    return m[0]

def chain_seq(chain):
    return "".join(AA3TO1.get(r.name.upper(), "X") for r in chain)

def find_subseq_allowX(hay, needle):
    i = hay.find(needle)
    if i >= 0:
        return i
    Lh, Ln = len(hay), len(needle)
    for i in range(Lh - Ln + 1):
        ok = True
        for a,b in zip(hay[i:i+Ln], needle):
            if a != "X" and a != b:
                ok = False
                break
        if ok:
            return i
    return -1

def bb_positions(chain, ris):
    res = list(chain)
    coords = []
    for i in ris:
        r = res[i]
        for name in ("N","CA","C","O"):
            a = r.find_atom(name, altloc="*")
            if a:
                p = a.pos
                coords.append([p.x,p.y,p.z])
    return np.array(coords, float)

def rmsd_superpose(P,Q):
    from MDAnalysis.analysis import rms
    n = min(len(P), len(Q))
    if n < 3:
        return np.nan
    return float(rms.rmsd(P[:n], Q[:n], superposition=True))

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--run_dir", required=True)
    ap.add_argument("--dp2_parquet", required=True)
    ap.add_argument("--pred_max", type=int, default=8)
    ap.add_argument("--out_csv", required=True)
    args = ap.parse_args()

    dp2 = pd.read_parquet(args.dp2_parquet)
    dp2["assay_scaffolded_epitope_id"] = dp2["assay_scaffolded_epitope_id"].str.lower()

    run_dir = Path(args.run_dir)
    rfd_root = run_dir / "02_rfd3" / "outputs"
    af3_root = run_dir / "03_af3" / "outputs"

    rows = []
    epi_fail = 0
    seqmatch_fail = 0

    toks = sorted(dp2["assay_scaffolded_epitope_id"].unique())

    for tok in toks:
        sub = dp2[dp2["assay_scaffolded_epitope_id"] == tok]
        for pred in range(args.pred_max):

            rfd3_path = next(rfd_root.glob(f"{tok}*model_{pred}.cif.gz"), None)
            af3_path  = next(af3_root.glob(f"{tok}*model_{pred}_model.cif"), None)

            if not rfd3_path or not af3_path:
                continue

            st_rfd = read_structure(rfd3_path)
            st_af3 = read_structure(af3_path)

            ch_rfd = get_chainA(st_rfd)
            ch_af3 = get_chainA(st_af3)

            seq_rfd = chain_seq(ch_rfd)
            seq_af3 = chain_seq(ch_af3)

            ws = find_subseq_allowX(seq_af3, seq_rfd)
            if ws < 0:
                seqmatch_fail += 1
                continue

            for _, r in sub.iterrows():
                rfd3_ris0 = list(r["scaffolded_epitope_chunk_resindices"])
                af3_ris0  = [ws + int(i) for i in rfd3_ris0]

                try:
                    P = bb_positions(ch_rfd, rfd3_ris0)
                    Q = bb_positions(ch_af3, af3_ris0)
                    epi = rmsd_superpose(P,Q)
                except Exception:
                    epi_fail += 1
                    continue

                rows.append({
                    "id": r["id"],
                    "tok": tok,
                    "pred": pred,
                    "epitope_chunk_rmsd": epi
                })

    out = pd.DataFrame(rows)
    out.to_csv(args.out_csv, index=False)

    print("DONE")
    print("rows:", len(out))
    print("seqmatch_fail:", seqmatch_fail)
    print("epi_fail:", epi_fail)

if __name__ == "__main__":
    main()
